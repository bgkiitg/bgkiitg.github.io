<div class="news">
  {% if site.kids != blank %}
    {% assign msg_size = site.kids | size %}
    <div
      class="table-responsive"
      {% if include.limit and site.announcements.scrollable and news_size > 3 %}
        style="max-height: 60vw"
      {% endif %}
    >

      <p><center><h3> Class 4A </h3> </center></p>

      <table class="table table-sm table-borderless">
        {% assign msgs = site.kids | reverse %}
        {% if include.limit and site.announcements.limit %}
          {% assign news_limit = site.announcements.limit %}
        {% else %}
          {% assign news_limit = news_size %}
        {% endif %}
        {% for msg in msgs limit: news_limit %}
	{% if msg.class == "4a" %}
          <tr>
            <th scope="row" style="width: 20%">{{ msg.date | date: '%b %d, %Y' }}</th>
            <td>
              {% if msg.inline %}
                {{ msg.content | remove: '<p>' | remove: '</p>' | emojify }}
              {% else %}
                <a class="news-title" href="{{ msg.url | relative_url }}">{{ msg.title }}</a>
              {% endif %}
            </td>
	    <td>
	    {{msg.messenger}}
	    </td>
          </tr>
	{% endif %}
        {% endfor %}
      </table>
 <p><center><h3> Class 6B </h3> </center></p>

<table class="table table-sm table-borderless">
